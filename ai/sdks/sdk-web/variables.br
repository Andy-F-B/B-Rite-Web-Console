// sdk-web variables
// paths resolve relative to root. read this file when !sdk|003| is active.
// wiring: SDK templates live here; outputs go to target paths below.

[system]
handbook = [root/AI_App_Development_Handbook_V2_1_fixed.txt]
webSdkDocs = [root/Web SDK Launch Instr PT.md]

[paths]
// SDK-internal (templates)
specs = [root/ai/sdks/sdk-web/specs/]
context = [root/ai/sdks/sdk-web/context/]
tasks = [root/ai/sdks/sdk-web/tasks/]
functions = [root/ai/sdks/sdk-web/functions/]
prompts = [root/ai/sdks/sdk-web/prompts/]
uiSchema = [root/ai/sdks/sdk-web/ui-schema/]

// Target paths (where outputs go at runtime)
aiSpecs = [root/ai/specs/]
aiContext = [root/ai/context/]
aiTasks = [root/ai/tasks/]
uiPreviews = [root/UI/]
output = [root/UI/dev-output/]
dbMigrations = [root/db/migrations/]
app = [root/app/]
components = [root/components/]
lib = [root/lib/]
featurePacks = [root/feature-packs/]

[stack]
nextjs, supabase, vercel

[breakpoints]
mobile = 600
tablet = 1024
laptop = 1440
desktop = 1920

[phases]
spec, anchor, task, migration, build, audit, preview

[files]
setupProcedure = [root/ai/sdks/sdk-web/setup-procedure.txt]
coreFeaturesPlan = [root/ai/sdks/sdk-web/core-features-plan.txt]
deployGuide = [root/ai/sdks/sdk-web/functions/deployGuide.br]
npmInstall = [root/ai/sdks/sdk-web/functions/npmInstall.br]
gitSetup = [root/ai/sdks/sdk-web/functions/gitSetup.br]
createTaskVariable = [root/ai/sdks/sdk-web/functions/taskVariable.br]

[taskVariables]
// task variables point to [root/ai/tasks/]. read; (varName) summarizes or pastes contents. camelCase from filename.
taskMiscChanges = [root/ai/tasks/task_misc_changes.md]
taskUiUpdates = [root/ai/tasks/task_ui_updates.md]
taskScriptEditorUpdates = [root/ai/tasks/task_script_editor_updates.md]
taskMiscLandingDownloadsNav = [root/ai/tasks/task_misc_landing_downloads_nav.md]
taskPublicLibraryAndEditorFixes = [root/ai/tasks/task_public_library_and_editor_fixes.md]
